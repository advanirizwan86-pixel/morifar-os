# Required: generate at least 32 random bytes. Never commit the real value.
AUTH_SECRET=
# Required only on first start to create the initial Super Admin (minimum 12 characters).
MORIFAR_BOOTSTRAP_PASSWORD=
MORIFAR_BOOTSTRAP_EMAIL=admin@your-company.com
MORIFAR_BOOTSTRAP_NAME=System Administrator
# Optional persistent database location.
MORIFAR_DATABASE_PATH=./data/morifar.db
